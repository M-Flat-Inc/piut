{
  "name": "@piut/cli",
  "version": "1.1.0",
  "description": "Automatic backup + hosting of all your agent configs across every machine. Version history. Restore any time. One command to set up.",
  "type": "module",
  "bin": {
    "piut": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "ai",
    "context",
    "cli",
    "claude",
    "cursor",
    "copilot",
    "windsurf",
    "backup",
    "sync",
    "cloud",
    "agent-config"
  ],
  "author": "M-Flat Inc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/M-Flat-Inc/piut"
  },
  "homepage": "https://piut.com",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "chokidar": "^4.0.3",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
